<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/DayNight"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/layout_height_56">

        <TextView
            style="@style/TextViewSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/ic_vector_buck"
            style="@style/BackButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"/>

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp">

        <EditText
            android:id="@+id/inputEditText"
            style="@style/EditTextSearch"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:autofillHints="text"
            tools:ignore="LabelFor" />

        <ImageButton
            android:id="@+id/imageButtonSearchClear"
            style="@style/ButtonCancelSearch"
            android:layout_width="@dimen/layout_width_40"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cancel"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_search_clear_16" />

    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tracksRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>