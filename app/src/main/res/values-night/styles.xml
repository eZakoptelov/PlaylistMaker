<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="SettingsStyle" parent="Widget.MaterialComponents.TextView">
        <item name="android:layout_marginStart">@dimen/marginStart_16</item>
        <item name="android:layout_marginTop">@dimen/marginTop_21</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:layout_marginEnd">@dimen/marginEnd_12</item>
        <item name="drawableEndCompat">@drawable/ic_switch_dark</item>
    </style>


    <style name="BlueBlackStyle" parent="Widget.MaterialComponents.CardView">
        <item name="android:background">@color/black</item>
    </style>


    <style name="EditTextSearch" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_marginStart">@dimen/marginStart_16</item>
        <item name="android:layout_marginEnd">@dimen/marginEnd_16</item>
        <item name="android:background">@drawable/rectangle_search</item>
        <item name="android:drawableStart">@drawable/ic_search</item>
        <item name="android:drawablePadding">@dimen/drawablePadding_8</item>
        <item name="android:paddingStart">@dimen/drawablePaddingStart_12</item>
        <item name="android:hint">@string/input_hint</item>
        <item name="android:textColorHint">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:fontFamily">@font/ys_text_regular</item>
        <item name="android:layout_alignParentStart">true</item>
        <item name="android:layout_centerVertical">true</item>
    </style>


</resources>